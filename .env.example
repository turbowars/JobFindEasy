# Copy to .env and fill in
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: pushover for mobile notifications
# PUSHOVER_TOKEN=
# PUSHOVER_USER=

# Optional: override default models.
# Resolution order for scoring-class tasks: per-task var -> SCORING_MODEL -> built-in default.
SCORING_MODEL=anthropic/claude-haiku-4.5
GENERATION_MODEL=anthropic/claude-sonnet-4.5

# Per-task scoring overrides (each falls back to SCORING_MODEL if unset):
JOB_SCORING_MODEL=google/gemini-2.0-flash-001   # 6-dim job-fit rubric (~200 calls/day) — cheap is right
# ATS_EXTRACT_MODEL=anthropic/claude-haiku-4.5  # JD keyword extractor; structured JSON output
# HR_SIM_MODEL=anthropic/claude-haiku-4.5       # recruiter-perspective resume score; judgment matters
# URL_EXTRACT_MODEL=anthropic/claude-haiku-4.5  # parses arbitrary job URL into Job dataclass
